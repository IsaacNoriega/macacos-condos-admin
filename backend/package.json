{
  "name": "backend",
  "version": "1.0.0",
  "description": "Macacos Condos Admin - Backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "worker": "nodemon --watch src --ext ts --exec ts-node src/worker.ts",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:reset": "ts-node src/scripts/reset-db.ts"
  },
  "type": "commonjs",
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "@azure/communication-sms": "^1.2.0-beta.4",
    "@azure/storage-blob": "^12.31.0",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.41.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.5.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdfmake": "^0.3.7",
    "puppeteer": "^24.42.0",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfmake": "^0.3.2",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
